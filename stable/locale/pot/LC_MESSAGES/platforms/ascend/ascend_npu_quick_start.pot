msgid "Ascend NPU Quickstart"
msgstr ""

#: ../../../platforms/ascend/ascend_npu_quick_start.md:3
msgid "Prerequisites"
msgstr ""

#: ../../../platforms/ascend/ascend_npu_quick_start.md:5
msgid "Supported Devices"
msgstr ""

#: ../../../platforms/ascend/ascend_npu_quick_start.md:7
msgid "Atlas 800I A2 inference series (Atlas 800I A2)"
msgstr ""

#: ../../../platforms/ascend/ascend_npu_quick_start.md:8
msgid "Atlas 800I A3 inference series (Atlas 800I A3)"
