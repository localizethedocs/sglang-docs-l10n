"   --attention-backend ascend \\\n"
"   --mm-attention-backend ascend_attn \\\n"
"   --trust-remote-code \\\n"
"   --tp-size 4 \\\n"
"   --model-path Qwen/Qwen3-VL-8B-Instruct \\\n"
"   --mem-fraction-static 0.8\n"
msgstr ""
