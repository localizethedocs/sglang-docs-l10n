#: ../../../advanced_features/object_storage.md:1
msgid "Loading Models from Object Storage"
msgstr ""

#: ../../../advanced_features/object_storage.md:3
msgid ""
"SGLang supports direct loading of models from object storage (S3 and Google "
"Cloud Storage) without requiring a full local download. This feature uses "
"the `runai_streamer` load format to stream model weights directly from cloud "
"storage, significantly reducing startup time and local storage requirements."
msgstr ""

#: ../../../advanced_features/object_storage.md:5
msgid "Overview"
msgstr ""

#: ../../../advanced_features/object_storage.md:7
msgid ""
"When loading models from object storage, SGLang uses a two-phase approach:"
msgstr ""

#: ../../../advanced_features/object_storage.md:9
msgid ""
"**Metadata Download** (once, before process launch): Configuration files and "
"tokenizer files are downloaded to a local cache"
msgstr ""

#: ../../../advanced_features/object_storage.md:10
msgid ""
"**Weight Streaming** (lazy, during model loading): Model weights are "
"streamed directly from object storage as needed"
msgstr ""

#: ../../../advanced_features/object_storage.md:12
msgid "Supported Storage Backends"
msgstr ""

#: ../../../advanced_features/object_storage.md:14
msgid "**Amazon S3**: `s3://bucket-name/path/to/model/`"
msgstr ""

#: ../../../advanced_features/object_storage.md:15
msgid "**Google Cloud Storage**: `gs://bucket-name/path/to/model/`"
msgstr ""

#: ../../../advanced_features/object_storage.md:16
msgid "**Azure Blob**: `az://some-azure-container/path/`"
msgstr ""

#: ../../../advanced_features/object_storage.md:17
msgid "**S3 compatible**: `s3://bucket-name/path/to/model/`"
msgstr ""

#: ../../../advanced_features/object_storage.md:19
msgid "Quick Start"
msgstr ""

#: ../../../advanced_features/object_storage.md:21
msgid "Basic Usage"
msgstr ""

#: ../../../advanced_features/object_storage.md:23
msgid "Simply provide an object storage URI as the model path:"
msgstr ""

#: ../../../advanced_features/object_storage.md:25
msgid ""
"# S3\n"
"python -m sglang.launch_server \\\n"
"  --model-path s3://my-bucket/models/llama-3-8b/ \\\n"
"  --load-format runai_streamer\n"
"\n"
"# Google Cloud Storage\n"
"python -m sglang.launch_server \\\n"
"  --model-path gs://my-bucket/models/llama-3-8b/ \\\n"
"  --load-format runai_streamer\n"
msgstr ""

#: ../../../advanced_features/object_storage.md:37
msgid ""
"**Note**: The `--load-format runai_streamer` is automatically detected when "
"using object storage URIs, so you can omit it:"
msgstr ""

#: ../../../advanced_features/object_storage.md:39
msgid ""
"python -m sglang.launch_server \\\n"
"  --model-path s3://my-bucket/models/llama-3-8b/\n"
msgstr ""

#: ../../../advanced_features/object_storage.md:44
msgid "With Tensor Parallelism"
msgstr ""

#: ../../../advanced_features/object_storage.md:46
msgid ""
"python -m sglang.launch_server \\\n"
"  --model-path gs://my-bucket/models/llama-70b/ \\\n"
"  --tp 4 \\\n"
"  --model-loader-extra-config '{\"distributed\": true}'\n"
msgstr ""

#: ../../../advanced_features/object_storage.md:53
msgid "Configuration"
msgstr ""

#: ../../../advanced_features/object_storage.md:55
msgid "Load Format"
msgstr ""

#: ../../../advanced_features/object_storage.md:57
msgid ""
"The `runai_streamer` load format is specifically designed for object "
"storage, ssd and shared file systems"
msgstr ""

#: ../../../advanced_features/object_storage.md:59
msgid ""
"python -m sglang.launch_server \\\n"
"  --model-path s3://bucket/model/ \\\n"
"  --load-format runai_streamer\n"
msgstr ""

#: ../../../advanced_features/object_storage.md:65
msgid "Extended Configuration Parameters"
msgstr ""

#: ../../../advanced_features/object_storage.md:67
msgid ""
"Use `--model-loader-extra-config` to pass additional configuration as a JSON "
"string:"
msgstr ""

#: ../../../advanced_features/object_storage.md:69
msgid ""
"python -m sglang.launch_server \\\n"
"  --model-path s3://bucket/model/ \\\n"
"  --model-loader-extra-config '{\n"
"    \"distributed\": true,\n"
"    \"concurrency\": 8,\n"
"    \"memory_limit\": 2147483648\n"
"  }'\n"
msgstr ""

