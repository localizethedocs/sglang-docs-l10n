#: ../../../advanced_features/object_storage.md:88
msgid "Performance Considerations"
msgstr ""

#: ../../../advanced_features/object_storage.md:90
msgid "Distributed Streaming"
msgstr ""

#: ../../../advanced_features/object_storage.md:92
msgid ""
"For multi-GPU setups, enable distributed streaming to parallelize weight "
"loading between the processes:"
msgstr ""

#: ../../../advanced_features/object_storage.md:94
msgid ""
"python -m sglang.launch_server \\\n"
"  --model-path s3://bucket/model/ \\\n"
"  --tp 8 \\\n"
"  --model-loader-extra-config '{\"distributed\": true}'\n"
msgstr ""

#: ../../../advanced_features/object_storage.md:101
msgid "Limitations"
msgstr ""

#: ../../../advanced_features/object_storage.md:103
msgid ""
"**Supported Formats**: Currently only supports `.safetensors` weight format "
"(recommended format)"
msgstr ""

#: ../../../advanced_features/object_storage.md:104
msgid ""
"**Supported Device**: Distributed streaming is supported on cuda alike "
"devices. Otherwise fallback to non distributed streaming"
msgstr ""

