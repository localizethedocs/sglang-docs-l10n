msgid "`candidate_steps`"
msgstr ""

#: ../../../advanced_features/adaptive_speculative_decoding.md:0
msgid "`[1, 3, 7]`"
msgstr ""

#: ../../../advanced_features/adaptive_speculative_decoding.md:0
msgid ""
"Discrete `speculative_num_steps` tiers that adaptive mode can switch between"
msgstr ""

#: ../../../advanced_features/adaptive_speculative_decoding.md:0
msgid "`ema_alpha`"
msgstr ""

#: ../../../advanced_features/adaptive_speculative_decoding.md:0
msgid "`0.2`"
msgstr ""

#: ../../../advanced_features/adaptive_speculative_decoding.md:0
msgid "EMA smoothing factor for accepted draft length"
msgstr ""

