msgstr ""

#: ../../../advanced_features/adaptive_speculative_decoding.md:0
msgid "Extra margin before moving to a larger step"
msgstr ""

#: ../../../advanced_features/adaptive_speculative_decoding.md:137
msgid ""
"The initial `--speculative-num-steps` is snapped to the nearest value in "
"`candidate_steps`."
msgstr ""

#: ../../../advanced_features/adaptive_speculative_decoding.md:139
msgid "Monitoring"
msgstr ""

#: ../../../advanced_features/adaptive_speculative_decoding.md:141
msgid ""
"You can inspect the active tier and acceptance metric via `/server_info`:"
msgstr ""

#: ../../../advanced_features/adaptive_speculative_decoding.md:143
msgid ""
"curl -s http://127.0.0.1:30000/server_info | jq '.internal_states[0] | "
"{speculative_num_steps, avg_spec_accept_length}'\n"
msgstr ""

#: ../../../advanced_features/adaptive_speculative_decoding.md:147
msgid "`speculative_num_steps` is the current active tier"
msgstr ""

#: ../../../advanced_features/adaptive_speculative_decoding.md:148
msgid ""
"`avg_spec_accept_length` helps explain whether the server is likely to move "
"up or down"
msgstr ""

#: ../../../advanced_features/adaptive_speculative_decoding.md:150
msgid "Tuning tips"
msgstr ""

#: ../../../advanced_features/adaptive_speculative_decoding.md:152
msgid "Start with the default candidate tiers `[1, 3, 7]`"
msgstr ""

#: ../../../advanced_features/adaptive_speculative_decoding.md:153
msgid "Use fewer tiers if you want lower startup and graph-memory overhead"
msgstr ""

#: ../../../advanced_features/adaptive_speculative_decoding.md:154
msgid "Increase `ema_alpha` to react faster, or lower it for more stability"
msgstr ""

#: ../../../advanced_features/adaptive_speculative_decoding.md:155
msgid ""
"Increase `warmup_batches` or `update_interval` if tier switching is too noisy"
msgstr ""

#: ../../../advanced_features/adaptive_speculative_decoding.md:156
msgid ""
"If your workload is already stable and one static setting is well tuned, "
"adaptive mode may not help much"
msgstr ""
