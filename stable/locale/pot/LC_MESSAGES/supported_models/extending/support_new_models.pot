#: ../../../supported_models/extending/support_new_models.md:424
msgid "Example: Multimodal Model"
msgstr ""

#: ../../../supported_models/extending/support_new_models.md:426
msgid ""
"If you are working with multimodal models, setting "
"`SGLANG_EXTERNAL_MODEL_PACKAGE` alone is not enough. SGLang also needs to "
"recognize your architecture as multimodal to enable the image/video "
"processing pipelines, and it needs a custom processor."
msgstr ""

#: ../../../supported_models/extending/support_new_models.md:428
msgid "You can handle this by setting two additional environment variables:"
msgstr ""

#: ../../../supported_models/extending/support_new_models.md:430
msgid ""
"`SGLANG_EXTERNAL_MM_MODEL_ARCH`: Adds your architecture name to SGLang's "
"internal list of multimodal models."
msgstr ""

#: ../../../supported_models/extending/support_new_models.md:431
msgid ""
"`SGLANG_EXTERNAL_MM_PROCESSOR_PACKAGE`: Tells SGLang where to find your "
"custom processor class."
msgstr ""

#: ../../../supported_models/extending/support_new_models.md:433
msgid ""
"For example, let's build a custom model based on Qwen2-VL-Instruct that "
"takes the square root of the logits."
msgstr ""

#: ../../../supported_models/extending/support_new_models.md:435
msgid "Create the project:"
msgstr ""

#: ../../../supported_models/extending/support_new_models.md:437
msgid ""
"sglang_custom_project_vl/\n"
"|----setup.py\n"
"|----custom_vlm/\n"
"     |----__init__.py\n"
"     |----qwenvl_wrapper.py\n"
msgstr ""

#: ../../../supported_models/extending/support_new_models.md:445
msgid "Write `setup.py`:"
msgstr ""

#: ../../../supported_models/extending/support_new_models.md:447
msgid ""
"# sglang_custom_project_vl/setup.py\n"
"\n"
"from setuptools import setup, find_packages\n"
"setup(\n"
"    name=\"sglang-custom-plugins-vl\",\n"
"    version=\"0.1\",\n"
"    packages=find_packages(),\n"
")\n"
msgstr ""

#: ../../../supported_models/extending/support_new_models.md:458
msgid "Write the model in `qwenvl_wrapper.py`:"
msgstr ""

#: ../../../supported_models/extending/support_new_models.md:460
msgid ""
"# sglang_custom_project_vl/custom_vlm/qwenvl_wrapper.py\n"
"import torch\n"
"from sglang.srt.models.qwen2_vl import Qwen2VLForConditionalGeneration\n"
"from sglang.srt.multimodal.processors.qwen_vl import QwenVLImageProcessor\n"
"\n"
"class CustomQwen2VL(Qwen2VLForConditionalGeneration):\n"
"    def forward(self, input_ids, positions, forward_batch,\n"
"                input_embeds=None, get_embedding=False):\n"
"        res = super().forward(\n"
"            input_ids, positions, forward_batch,\n"
"            input_embeds=input_embeds, get_embedding=get_embedding\n"
"        )\n"
"        if not get_embedding:\n"
"            orig = res.next_token_logits\n"
"            res.next_token_logits = torch.where(orig > 0, orig.sqrt(), "
"orig)\n"
"        return res\n"
"\n"
"class CustomQwen2VLProcessor(QwenVLImageProcessor):\n"
"    models = [CustomQwen2VL]\n"
"\n"
"    def __init__(self, hf_config, server_args, _processor, *args, "
"**kwargs):\n"
"        super().__init__(hf_config, server_args, _processor, *args, "
"**kwargs)\n"
"\n"
"EntryClass = CustomQwen2VL\n"
msgstr ""

#: ../../../supported_models/extending/support_new_models.md:487
msgid ""
"**Note:** you don't need a separate `EntryClass` for the custom processor as "
"long as you associate the processor with the specific model class."
msgstr ""

