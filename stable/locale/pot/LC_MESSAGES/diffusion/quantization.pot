#: ../../../diffusion/quantization.md:1
msgid "Quantization"
msgstr ""

#: ../../../diffusion/quantization.md:3
msgid ""
"SGLang-Diffusion supports quantized transformer checkpoints. In most cases, "
"keep the base model and the quantized transformer override separate."
msgstr ""

#: ../../../diffusion/quantization.md:6
msgid "Quick Reference"
msgstr ""

#: ../../../diffusion/quantization.md:8
msgid "Use these paths:"
msgstr ""

#: ../../../diffusion/quantization.md:10
msgid "`--model-path`: the base or original model"
msgstr ""

#: ../../../diffusion/quantization.md:11
msgid ""
"`--transformer-path`: a quantized transformers-style transformer component "
"directory that already contains its own `config.json`"
msgstr ""

#: ../../../diffusion/quantization.md:12
msgid ""
"`--transformer-weights-path`: quantized transformer weights provided as a "
"single safetensors file, a sharded safetensors directory, a local path, or a "
"Hugging Face repo ID"
msgstr ""

#: ../../../diffusion/quantization.md:14
msgid "Recommended example:"
msgstr ""

#: ../../../diffusion/quantization.md:16
msgid ""
"sglang generate \\\n"
"  --model-path black-forest-labs/FLUX.2-dev \\\n"
"  --transformer-weights-path black-forest-labs/FLUX.2-dev-NVFP4 \\\n"
"  --prompt \"a curious pikachu\"\n"
msgstr ""

#: ../../../diffusion/quantization.md:23
msgid "For quantized transformers-style transformer component folders:"
msgstr ""

#: ../../../diffusion/quantization.md:25
msgid ""
"sglang generate \\\n"
"  --model-path /path/to/base-model \\\n"
"  --transformer-path /path/to/quantized-transformer \\\n"
"  --prompt \"A Logo With Bold Large Text: SGL Diffusion\"\n"
msgstr ""

#: ../../../diffusion/quantization.md:32
msgid ""
"NOTE: Some model-specific integrations also accept a quantized repo or local "
"directory directly as `--model-path`, but that is a compatibility path. If a "
"repo contains multiple candidate checkpoints, pass `--transformer-weights-"
"path` explicitly."
msgstr ""

