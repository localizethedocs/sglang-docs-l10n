#: ../../../diffusion/disaggregation.md:190
msgid ""
"from sglang.multimodal_gen.runtime.server_args import ServerArgs\n"
"from sglang.multimodal_gen.runtime.launch_server import "
"launch_pool_disagg_server\n"
"\n"
"server_args = ServerArgs.from_kwargs(\n"
"    model_path=\"Wan-AI/Wan2.1-T2V-14B-Diffusers\",\n"
"    denoiser_sp=4, denoiser_ulysses=2, denoiser_ring=2,\n"
"    disagg_ib_device=\"mlx5_0\",\n"
")\n"
"\n"
"launch_pool_disagg_server(\n"
"    server_args,\n"
"    encoder_gpus=[[0]],\n"
"    denoiser_gpus=[[1, 2, 3, 4], [5, 6, 7, 8]],\n"
"    decoder_gpus=[[0]],\n"
")\n"
msgstr ""

#: ../../../diffusion/disaggregation.md:208
msgid "Architecture"
msgstr ""

#: ../../../diffusion/disaggregation.md:210
msgid ""
"Client ─── HTTP (port 30000) ──► FastAPI Server\n"
"                                      │\n"
"                                      ▼\n"
"                              DiffusionServer (ROUTER, scheduler_port)\n"
"                              ┌───────┼───────┐\n"
"                   PUSH work  │       │       │  PUSH work\n"
"                              ▼       │       ▼\n"
"                    Encoder[0..N]     │    Decoder[0..K]\n"
"                              │       │       ▲\n"
"                   P2P tensor │       │       │ P2P tensor\n"
"                   transfer   ▼       │       │ transfer\n"
"                          Denoiser[0..M] ─────┘\n"
"                                      │\n"
"                    PULL results ◄────┘  (decoder → DS → client)\n"
msgstr ""

#: ../../../diffusion/disaggregation.md:227
msgid "Request State Machine"
msgstr ""

#: ../../../diffusion/disaggregation.md:229
msgid ""
"PENDING → ENCODER_WAITING → ENCODER_RUNNING → ENCODER_DONE\n"
"                                                    │\n"
"                        DENOISING_WAITING → DENOISING_RUNNING → "
"DENOISING_DONE\n"
"                                                                       │\n"
"                                    DECODER_WAITING → DECODER_RUNNING → "
"DONE\n"
msgstr ""

#: ../../../diffusion/disaggregation.md:237
msgid "Any state can transition to `FAILED` or `TIMED_OUT`."
msgstr ""
