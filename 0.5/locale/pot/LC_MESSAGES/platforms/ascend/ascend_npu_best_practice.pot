msgid ""
"export SGLANG_DP_ROUND_ROBIN=1\n"
"python -m sglang_router.launch_router \\\n"
"    --pd-disaggregation \\\n"
"    --policy cache_aware \\\n"
"    --prefill http://P_IP:8000 8998 \\\n"
