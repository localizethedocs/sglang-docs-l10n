#: ../../../advanced_features/quantization.md:302
msgid "**Why quantize?**"
msgstr ""

#: ../../../advanced_features/quantization.md:303
msgid "Reduce VRAM usage"
msgstr ""

#: ../../../advanced_features/quantization.md:304
