#: ../../../diffusion/index.md:1
msgid "SGLang Diffusion"
msgstr ""

#: ../../../diffusion/index.md:3
msgid ""
"SGLang Diffusion is a high-performance inference framework for image and "
"video generation. It provides native SGLang pipelines, diffusers backend "
"support, an OpenAI-compatible server, and an optimized kernel stack built on "
"both precompiled `sgl-kernel` operators and JIT kernels for key inference "
"paths."
msgstr ""

#: ../../../diffusion/index.md:5
msgid "Key Features"
msgstr ""

#: ../../../diffusion/index.md:7
msgid ""
"Broad model support across Wan, Hunyuan, Qwen-Image, FLUX, Z-Image, GLM-"
"Image, and more"
msgstr ""

#: ../../../diffusion/index.md:8
msgid ""
"Fast inference with `sgl-kernel`, JIT kernels, scheduler improvements, and "
"caching acceleration"
msgstr ""

#: ../../../diffusion/index.md:9
msgid ""
"Multiple interfaces: `sglang generate`, `sglang serve`, and an OpenAI-"
"compatible API"
msgstr ""

#: ../../../diffusion/index.md:10
msgid ""
"Multi-platform support for NVIDIA, AMD, Intel XPU, Ascend, Apple Silicon, "
"and Moore Threads"
msgstr ""

#: ../../../diffusion/index.md:12
msgid "Quick Start"
msgstr ""

#: ../../../diffusion/index.md:14
msgid "uv pip install \"sglang[diffusion]\" --prerelease=allow\n"
msgstr ""

#: ../../../diffusion/index.md:18
msgid ""
"sglang generate --model-path Qwen/Qwen-Image \\\n"
"  --prompt \"A beautiful sunset over the mountains\" \\\n"
"  --save-output\n"
msgstr ""

#: ../../../diffusion/index.md:24
msgid "sglang serve --model-path Qwen/Qwen-Image --port 30010\n"
msgstr ""

