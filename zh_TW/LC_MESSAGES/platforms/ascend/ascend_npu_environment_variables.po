#: ../../../platforms/ascend/ascend_npu_environment_variables.md:1
msgid "Environment Variables"
msgstr "環境變數"

#: ../../../platforms/ascend/ascend_npu_environment_variables.md:3
msgid ""
"SGLang supports various environment variables related to Ascend NPU that can "
"be used to configure its runtime behavior. This document provides a list of "
"commonly used environment variables and aims to stay updated over time."
msgstr ""

#: ../../../platforms/ascend/ascend_npu_environment_variables.md:6
msgid "Directly Used in SGLang"
msgstr ""

#: ../../../platforms/ascend/ascend_npu_environment_variables.md:0
msgid "Environment Variable"
msgstr "環境變數"

#: ../../../platforms/ascend/ascend_npu_environment_variables.md:0
msgid "Description"
msgstr "描述"

#: ../../../platforms/ascend/ascend_npu_environment_variables.md:0
msgid "Default Value"
msgstr ""

#: ../../../platforms/ascend/ascend_npu_environment_variables.md:0
msgid "`SGLANG_NPU_USE_MLAPO`"
msgstr ""

#: ../../../platforms/ascend/ascend_npu_environment_variables.md:0
msgid ""
"Adopts the `MLAPO` fusion operator in attention <br/> preprocessing stage of "
"the MLA model."
msgstr ""

#: ../../../platforms/ascend/ascend_npu_environment_variables.md:10
#: ../../../platforms/ascend/ascend_npu_environment_variables.md:11
#: ../../../platforms/ascend/ascend_npu_environment_variables.md:12
#: ../../../platforms/ascend/ascend_npu_environment_variables.md:13
#: ../../../platforms/ascend/ascend_npu_environment_variables.md:20
#: ../../../platforms/ascend/ascend_npu_environment_variables.md:21
#: ../../../platforms/ascend/ascend_npu_environment_variables.md:22
#: ../../../platforms/ascend/ascend_npu_environment_variables.md:23
#: ../../../platforms/ascend/ascend_npu_environment_variables.md:30
#: ../../../platforms/ascend/ascend_npu_environment_variables.md:33
#: ../../../platforms/ascend/ascend_npu_environment_variables.md:34
#: ../../../platforms/ascend/ascend_npu_environment_variables.md:37
#: ../../../platforms/ascend/ascend_npu_environment_variables.md:38
msgid "<br/>"
msgstr ""

#: ../../../platforms/ascend/ascend_npu_environment_variables.md:0
msgid "`false`"
msgstr ""

#: ../../../platforms/ascend/ascend_npu_environment_variables.md:0
msgid "`SGLANG_USE_FIA_NZ`"
msgstr ""

#: ../../../platforms/ascend/ascend_npu_environment_variables.md:0
msgid ""
"Reshapes KV Cache for FIA NZ format.<br/> `SGLANG_USE_FIA_NZ` must be "
"enabled with `SGLANG_NPU_USE_MLAPO`"
msgstr ""

#: ../../../platforms/ascend/ascend_npu_environment_variables.md:0
msgid "`SGLANG_NPU_USE_MULTI_STREAM`"
msgstr ""

#: ../../../platforms/ascend/ascend_npu_environment_variables.md:0
msgid ""
"Enable dual-stream computation of shared experts <br/> and routing experts "
"in DeepSeek models.<br/> Enable dual-stream computation in DeepSeek NSA "
"Indexer."
msgstr ""

#: ../../../platforms/ascend/ascend_npu_environment_variables.md:0
msgid "`SGLANG_NPU_DISABLE_ACL_FORMAT_WEIGHT`"
msgstr ""

#: ../../../platforms/ascend/ascend_npu_environment_variables.md:0
msgid "Disable cast model weight tensor to a specific NPU <br/> ACL format."
msgstr ""

#: ../../../platforms/ascend/ascend_npu_environment_variables.md:0
msgid "`SGLANG_DEEPEP_NUM_MAX_DISPATCH_TOKENS_PER_RANK`"
msgstr ""

#: ../../../platforms/ascend/ascend_npu_environment_variables.md:0
msgid "The maximum number of dispatched tokens on each rank."
msgstr ""

#: ../../../platforms/ascend/ascend_npu_environment_variables.md:0
msgid "`128`"
msgstr ""

#: ../../../platforms/ascend/ascend_npu_environment_variables.md:16
msgid "Used in DeepEP Ascend"
msgstr ""

#: ../../../platforms/ascend/ascend_npu_environment_variables.md:0
msgid "`DEEPEP_NORMAL_LONG_SEQ_PER_ROUND_TOKENS`"
msgstr ""

#: ../../../platforms/ascend/ascend_npu_environment_variables.md:0
msgid ""
"Enable ant-moving function in dispatch stage. Indicates <br/> the number of "
"tokens transmitted per round on each rank."
msgstr ""

#: ../../../platforms/ascend/ascend_npu_environment_variables.md:0
msgid "`8192`"
msgstr ""

#: ../../../platforms/ascend/ascend_npu_environment_variables.md:0
msgid "`DEEPEP_NORMAL_LONG_SEQ_ROUND`"
msgstr ""

#: ../../../platforms/ascend/ascend_npu_environment_variables.md:0
msgid ""
"Enable ant-moving function in dispatch stage. Indicates <br/> the number of "
"rounds transmitted on each rank."
msgstr ""

#: ../../../platforms/ascend/ascend_npu_environment_variables.md:0
msgid "`1`"
msgstr ""

#: ../../../platforms/ascend/ascend_npu_environment_variables.md:0
msgid "`DEEPEP_NORMAL_COMBINE_ENABLE_LONG_SEQ`"
msgstr ""

#: ../../../platforms/ascend/ascend_npu_environment_variables.md:0
msgid ""
"Enable ant-moving function in combine stage. <br/> The value `0` means "
"disabled."
msgstr ""

#: ../../../platforms/ascend/ascend_npu_environment_variables.md:0
msgid "`0`"
msgstr ""

#: ../../../platforms/ascend/ascend_npu_environment_variables.md:0
msgid "`MOE_ENABLE_TOPK_NEG_ONE`"
msgstr ""

#: ../../../platforms/ascend/ascend_npu_environment_variables.md:0
msgid ""
"Needs to be enabled when the expert ID to be processed by <br/> DEEPEP "
"contains -1."
msgstr ""

#: ../../../platforms/ascend/ascend_npu_environment_variables.md:0
msgid "`DEEP_NORMAL_MODE_USE_INT8_QUANT`"
msgstr ""

#: ../../../platforms/ascend/ascend_npu_environment_variables.md:0
msgid "Quantizes x to int8 and returns (tensor, scales) in dispatch operator."
msgstr ""

#: ../../../platforms/ascend/ascend_npu_environment_variables.md:26
msgid "Others"
msgstr ""

#: ../../../platforms/ascend/ascend_npu_environment_variables.md:0
msgid "`TASK_QUEUE_ENABLE`"
msgstr ""

#: ../../../platforms/ascend/ascend_npu_environment_variables.md:0
msgid ""
"Used to control the optimization level of the dispatch queue<br/> about the "
"task_queue operator. [Detail](https://www.hiascend.com/document/detail/zh/"
"Pytorch/730/comref/Envvariables/docs/zh/environment_variable_reference/"
"TASK_QUEUE_ENABLE.md)"
msgstr ""

#: ../../../platforms/ascend/ascend_npu_environment_variables.md:0
msgid "`INF_NAN_MODE_ENABLE`"
msgstr ""

#: ../../../platforms/ascend/ascend_npu_environment_variables.md:0
msgid ""
"Controls whether the chip uses saturation mode or INF_NAN mode. [Detail]"
"(https://www.hiascend.com/document/detail/zh/"
"CANNCommunityEdition/800alpha001/apiref/envref/envref_07_0056.html)"
msgstr ""

#: ../../../platforms/ascend/ascend_npu_environment_variables.md:0
msgid "`STREAMS_PER_DEVICE`"
msgstr ""

#: ../../../platforms/ascend/ascend_npu_environment_variables.md:0
msgid ""
"Configures the maximum number of streams for the stream pool. [Detail]"
"(https://www.hiascend.com/document/detail/zh/Pytorch/720/comref/Envvariables/"
"Envir_041.html)"
msgstr ""

#: ../../../platforms/ascend/ascend_npu_environment_variables.md:0
msgid "`32`"
msgstr ""

#: ../../../platforms/ascend/ascend_npu_environment_variables.md:0
msgid "`PYTORCH_NPU_ALLOC_CONF`"
msgstr ""

#: ../../../platforms/ascend/ascend_npu_environment_variables.md:0
msgid ""
"Controls the behavior of the cache allocator. <br/>This variable changes "
"memory usage and may cause performance fluctuations. [Detail](https://www."
"hiascend.com/document/detail/zh/Pytorch/700/comref/Envvariables/Envir_012."
"html)"
msgstr ""

#: ../../../platforms/ascend/ascend_npu_environment_variables.md:0
msgid "`ASCEND_MF_STORE_URL`"
msgstr ""

#: ../../../platforms/ascend/ascend_npu_environment_variables.md:0
msgid ""
"The address of config store in MemFabric during PD separation, <br/>which is "
"generally set to the IP address of the P primary node<br/> with an arbitrary "
"port number."
msgstr ""

#: ../../../platforms/ascend/ascend_npu_environment_variables.md:0
msgid "`ASCEND_LAUNCH_BLOCKING`"
msgstr ""

#: ../../../platforms/ascend/ascend_npu_environment_variables.md:0
msgid ""
"Controls whether synchronous mode is enabled during operator execution. "
"[Detail](https://www.hiascend.com/document/detail/zh/Pytorch/710/comref/"
"Envvariables/Envir_006.html)"
msgstr ""

#: ../../../platforms/ascend/ascend_npu_environment_variables.md:0
msgid "`HCCL_OP_EXPANSION_MODE`"
msgstr ""

#: ../../../platforms/ascend/ascend_npu_environment_variables.md:0
msgid ""
"Configures the expansion position for communication algorithm scheduling. "
"[Detail](https://www.hiascend.com/document/detail/zh/"
"CANNCommunityEdition/800alpha001/apiref/envref/envref_07_0094.html)"
msgstr ""

#: ../../../platforms/ascend/ascend_npu_environment_variables.md:0
msgid "`HCCL_BUFFSIZE`"
msgstr ""

#: ../../../platforms/ascend/ascend_npu_environment_variables.md:0
msgid ""
"Controls the size of the buffer area for shared data between two NPUs. <br/"
">The unit is MB, and the value must be greater than or equal to 1. [Detail]"
"(https://www.hiascend.com/document/detail/zh/Pytorch/60RC3/ptmoddevg/"
"trainingmigrguide/performance_tuning_0047.html)"
msgstr ""

#: ../../../platforms/ascend/ascend_npu_environment_variables.md:0
msgid "`200`"
msgstr ""

#: ../../../platforms/ascend/ascend_npu_environment_variables.md:0
msgid "`HCCL_SOCKET_IFNAME`"
msgstr ""

#: ../../../platforms/ascend/ascend_npu_environment_variables.md:0
msgid ""
"Configures the name of the network card used by the Host <br/>during HCCL "
"initialization. [Detail](https://www.hiascend.com/document/detail/zh/"
"canncommercial/81RC1/apiref/envvar/envref_07_0075.html)"
msgstr ""

#: ../../../platforms/ascend/ascend_npu_environment_variables.md:0
msgid "`GLOO_SOCKET_IFNAME`"
msgstr ""

#: ../../../platforms/ascend/ascend_npu_environment_variables.md:0
msgid "Configures the network interface name for GLOO communication."
msgstr ""
