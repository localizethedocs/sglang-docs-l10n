"        --speculative-algorithm EAGLE3 --speculative-draft-model-path xxx "
"\\\n"
"        --speculative-draft-model-quantization unquant \\\n"
"        --speculative-num-steps 3 --speculative-eagle-topk 1 --speculative-"
