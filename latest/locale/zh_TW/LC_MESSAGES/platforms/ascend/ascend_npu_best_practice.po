"context-length 8192 \\\n"
"        --enable-dp-lm-head --dtype bfloat16 --tokenizer-worker-num 4 \\\n"
"        --load-balance-method decode_round_robin\n"
"        NODE_RANK=$i\n"
"        break\n"
"    fi\n"
"done\n"
"\n"
