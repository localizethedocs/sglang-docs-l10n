#: ../../../diffusion/environment_variables.md:46
msgid "CUDA Crash Debugging"
msgstr ""

#: ../../../diffusion/environment_variables.md:48
msgid ""
"These variables enable kernel API logging and optional input/output dumps "
"around diffusion CUDA kernel call boundaries. They are useful when tracking "
"down CUDA crashes such as illegal memory access, device-side assert, or "
"shape mismatches in custom kernels."
msgstr ""

#: ../../../diffusion/environment_variables.md:0
msgid "`SGLANG_KERNEL_API_LOGLEVEL`"
msgstr ""

#: ../../../diffusion/environment_variables.md:0
msgid "`0`"
msgstr ""

#: ../../../diffusion/environment_variables.md:0
msgid ""
"Controls crash-debug kernel API logging. `1` logs API names, `3` logs tensor "
"metadata, `5` adds tensor statistics, and `10` also writes dump snapshots."
msgstr ""

#: ../../../diffusion/environment_variables.md:0
msgid "`SGLANG_KERNEL_API_LOGDEST`"
msgstr ""

#: ../../../diffusion/environment_variables.md:0
msgid "`stdout`"
msgstr ""

#: ../../../diffusion/environment_variables.md:0
msgid ""
"Destination for crash-debug kernel API logs. Use `stdout`, `stderr`, or a "
"file path. `%i` is replaced with the process PID."
msgstr ""

#: ../../../diffusion/environment_variables.md:0
msgid "`SGLANG_KERNEL_API_DUMP_DIR`"
msgstr ""

#: ../../../diffusion/environment_variables.md:0
msgid "`sglang_kernel_api_dumps`"
msgstr ""

#: ../../../diffusion/environment_variables.md:0
msgid ""
"Output directory for level-10 kernel API dumps. `%i` is replaced with the "
"process PID."
msgstr ""

#: ../../../diffusion/environment_variables.md:0
msgid "`SGLANG_KERNEL_API_DUMP_INCLUDE`"
msgstr ""

#: ../../../diffusion/environment_variables.md:0
msgid ""
"Comma-separated wildcard patterns for kernel API names to include in "
"level-10 dumps."
msgstr ""

#: ../../../diffusion/environment_variables.md:0
msgid "`SGLANG_KERNEL_API_DUMP_EXCLUDE`"
msgstr ""

#: ../../../diffusion/environment_variables.md:0
msgid ""
"Comma-separated wildcard patterns for kernel API names to exclude from "
"level-10 dumps."
msgstr ""
