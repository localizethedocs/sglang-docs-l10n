#: ../../../platforms/plugin.md:98 ../../../platforms/plugin.md:270
msgid "Quick Start"
msgstr ""

#: ../../../platforms/plugin.md:100 ../../../platforms/plugin.md:272
msgid "**1. Create a minimal package:**"
msgstr ""

#: ../../../platforms/plugin.md:102
msgid ""
"my_platform_plugin/\n"
"├── pyproject.toml\n"
"└── my_platform_plugin/\n"
"    ├── __init__.py    # activate() function\n"
"    ├── device.py      # MyDeviceMixin\n"
"    └── platform.py    # MySRTPlatform\n"
msgstr ""

#: ../../../platforms/plugin.md:111 ../../../platforms/plugin.md:281
msgid "**2. `pyproject.toml`:**"
msgstr ""

#: ../../../platforms/plugin.md:113
msgid ""
"[build-system]\n"
"requires = [\"setuptools\"]\n"
"build-backend = \"setuptools.build_meta\"\n"
"\n"
"[project]\n"
"name = \"my-platform-plugin\"\n"
"version = \"0.1.0\"\n"
"\n"
"[project.entry-points.\"sglang.srt.platforms\"]\n"
"my_device = \"my_platform_plugin:activate\"\n"
msgstr ""

#: ../../../platforms/plugin.md:126
msgid "**3. `__init__.py`** — activation function:"
msgstr ""

#: ../../../platforms/plugin.md:128
msgid ""
"def activate():\n"
"    \"\"\"Return fully-qualified class name to activate, or None to skip."
"\"\"\"\n"
"    if _my_device_is_available():\n"
"        return \"my_platform_plugin.platform.MySRTPlatform\"\n"
"    return None\n"
msgstr ""

#: ../../../platforms/plugin.md:136
msgid "**4. `device.py`** — device mixin:"
msgstr ""

#: ../../../platforms/plugin.md:138
msgid ""
"from sglang.srt.platforms.device_mixin import DeviceMixin, PlatformEnum\n"
"\n"
"class MyDeviceMixin(DeviceMixin):\n"
"    _enum = PlatformEnum.OOT\n"
"    device_name = \"my_device\"\n"
"    device_type = \"my_device\"   # torch device type\n"
"\n"
"    def set_device(self, device) -> None: ...\n"
"    def get_device_name(self, device_id=0) -> str: ...\n"
"    def get_device_total_memory(self, device_id=0) -> int: ...\n"
"    def get_current_memory_usage(self, device=None) -> float: ...\n"
"    def get_device_capability(self, device_id=0): ...\n"
"    def get_torch_distributed_backend_str(self) -> str: ...\n"
msgstr ""

#: ../../../platforms/plugin.md:154
msgid "**5. `platform.py`** — SRT platform:"
msgstr ""

#: ../../../platforms/plugin.md:156
msgid ""
"from sglang.srt.platforms.interface import SRTPlatform\n"
"from my_platform_plugin.device import MyDeviceMixin\n"
"\n"
"class MySRTPlatform(SRTPlatform, MyDeviceMixin):\n"
"    def get_default_attention_backend(self) -> str: ...\n"
"    def support_cuda_graph(self) -> bool: ...\n"
"    # ... override other methods as needed\n"
msgstr ""

#: ../../../platforms/plugin.md:166
msgid "**6. Install and verify:**"
msgstr ""

#: ../../../platforms/plugin.md:168
msgid ""
"pip install -e my_platform_plugin/\n"
"python -c \"from sglang.srt.platforms import current_platform; "
"print(current_platform)\"\n"
msgstr ""

