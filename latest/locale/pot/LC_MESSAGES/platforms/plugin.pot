msgid ""
"my_general_plugin/\n"
"├── pyproject.toml\n"
"└── my_general_plugin/\n"
"    └── __init__.py    # register() function\n"
msgstr ""

#: ../../../platforms/plugin.md:283
msgid ""
"[build-system]\n"
"requires = [\"setuptools\"]\n"
"build-backend = \"setuptools.build_meta\"\n"
"\n"
"[project]\n"
"name = \"my-general-plugin\"\n"
"version = \"0.1.0\"\n"
"\n"
"[project.entry-points.\"sglang.srt.plugins\"]\n"
"my_plugin = \"my_general_plugin:register\"\n"
msgstr ""

#: ../../../platforms/plugin.md:296
msgid "**3. `__init__.py`** — register hooks:"
msgstr ""

#: ../../../platforms/plugin.md:298
msgid ""
"from sglang.srt.plugins.hook_registry import HookRegistry, HookType\n"
"\n"
"def register():\n"
"    \"\"\"Entry point called by load_plugins().\"\"\"\n"
"    HookRegistry.register(\n"
"        \"sglang.srt.managers.scheduler.Scheduler.__init__\",\n"
"        my_hook,\n"
"        HookType.AROUND,\n"
"    )\n"
"\n"
"def my_hook(original_fn, self, *args, **kwargs):\n"
"    result = original_fn(self, *args, **kwargs)\n"
"    print(f\"Scheduler initialized! gpu_id={self.gpu_id}\")\n"
"    return result\n"
msgstr ""

#: ../../../platforms/plugin.md:315
msgid "**4. Install and run:**"
msgstr ""

#: ../../../platforms/plugin.md:317
msgid ""
"pip install -e my_general_plugin/\n"
"sglang serve --model-path <model> [options]\n"
"# Look for \"Scheduler initialized!\" in logs\n"
msgstr ""

#: ../../../platforms/plugin.md:323
msgid "Hook Types"
msgstr ""

#: ../../../platforms/plugin.md:325
msgid "`HookRegistry` supports four hook types:"
msgstr ""

#: ../../../platforms/plugin.md:0
msgid "Hook Type"
msgstr ""

#: ../../../platforms/plugin.md:0
msgid "Signature"
msgstr ""

#: ../../../platforms/plugin.md:0
msgid "**BEFORE**"
msgstr ""

#: ../../../platforms/plugin.md:0
msgid "`fn(*args, **kwargs) -> (args, kwargs) | None`"
msgstr ""

#: ../../../platforms/plugin.md:0
msgid ""
"Runs before the original. Return `None` to keep args unchanged, or `(args, "
"kwargs)` to modify."
msgstr ""

#: ../../../platforms/plugin.md:0
msgid "**AFTER**"
msgstr ""

#: ../../../platforms/plugin.md:0
msgid "`fn(result, *args, **kwargs) -> new_result | None`"
msgstr ""

#: ../../../platforms/plugin.md:0
msgid ""
"Runs after the original. Return `None` to keep result, or a new value to "
"replace."
msgstr ""

#: ../../../platforms/plugin.md:0
msgid "**AROUND**"
msgstr ""

#: ../../../platforms/plugin.md:0
msgid "`fn(original_fn, *args, **kwargs) -> result`"
msgstr ""

#: ../../../platforms/plugin.md:0
msgid ""
"Wraps the original. You must call `original_fn` yourself. Full control over "
"execution."
msgstr ""

#: ../../../platforms/plugin.md:0
msgid "**REPLACE**"
msgstr ""

#: ../../../platforms/plugin.md:0
msgid "`fn(*args, **kwargs) -> result` or `class`"
msgstr ""

#: ../../../platforms/plugin.md:0
msgid ""
"Replace the original function or class entirely. For class targets, pass a "
"replacement class directly — it is substituted via `setattr` preserving "
"`isinstance()`/`issubclass()` semantics."
msgstr ""

#: ../../../platforms/plugin.md:334
msgid ""
"**Note**: Only `REPLACE` accepts a class as the hook. Passing a class to "
"`BEFORE`/`AFTER`/`AROUND` raises `TypeError` at registration time."
msgstr ""

#: ../../../platforms/plugin.md:336
msgid "Registration API"
msgstr ""

#: ../../../platforms/plugin.md:338
msgid ""
"Hooks can be registered using the **imperative API** or the **decorator "
"API**:"
msgstr ""

#: ../../../platforms/plugin.md:340
msgid ""
"# --- Imperative API ---\n"
"from sglang.srt.plugins.hook_registry import HookRegistry, HookType\n"
"\n"
"def my_timer(original_fn, *args, **kwargs):\n"
"    start = time.perf_counter()\n"
"    result = original_fn(*args, **kwargs)\n"
"    print(f\"Elapsed: {time.perf_counter() - start:.3f}s\")\n"
"    return result\n"
"\n"
"HookRegistry.register(\n"
"    \"sglang.srt.managers.scheduler.Scheduler.get_next_batch_to_run\",\n"
"    my_timer,\n"
"    HookType.AROUND,\n"
")\n"
"\n"
"# --- Decorator API ---\n"
"from sglang.srt.plugins.hook_registry import plugin_hook, HookType\n"
"\n"
"@plugin_hook(\n"
"    \"sglang.srt.managers.scheduler.Scheduler.get_next_batch_to_run\",\n"
"    type=HookType.AROUND,\n"
")\n"
"def my_timer(original_fn, *args, **kwargs):\n"
"    start = time.perf_counter()\n"
"    result = original_fn(*args, **kwargs)\n"
"    print(f\"Elapsed: {time.perf_counter() - start:.3f}s\")\n"
"    return result\n"
"\n"
"# --- Class replacement (REPLACE) ---\n"
"from sglang.srt.plugins.hook_registry import plugin_hook, HookType\n"
"from sglang.srt.managers.scheduler import Scheduler\n"
"\n"
"@plugin_hook(\n"
"    \"sglang.srt.managers.scheduler.Scheduler\",\n"
"    type=HookType.REPLACE,\n"
")\n"
"class MyScheduler(Scheduler):\n"
"    def __init__(self, *args, **kwargs):\n"
"        super().__init__(*args, **kwargs)\n"
"        print(\"Enhanced scheduler initialized!\")\n"
msgstr ""

