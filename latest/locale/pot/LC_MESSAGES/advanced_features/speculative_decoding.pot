#: ../../../advanced_features/speculative_decoding.md:0
msgid "`12` (with default ngram settings)"
msgstr ""

#: ../../../advanced_features/speculative_decoding.md:0
msgid "`--speculative-ngram-min-bfs-breadth`"
msgstr ""

#: ../../../advanced_features/speculative_decoding.md:0
