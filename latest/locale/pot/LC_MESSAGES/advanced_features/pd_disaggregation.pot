#: ../../../advanced_features/pd_disaggregation.md:160
msgid "Heterogeneous TP with GPU Staging Buffer"
msgstr ""

#: ../../../advanced_features/pd_disaggregation.md:162
msgid ""
"When prefill and decode use different tensor parallelism (TP) sizes (e.g., "
"prefill TP=4, decode DP attention with TP=1), the KV cache memory layout "
"differs between the two sides. The **GPU staging buffer** solves this by "
"gathering KV head slices into a contiguous buffer on the prefill side, "
"performing bulk RDMA transfer, then scattering into the correct KV cache "
"pages on the decode side. This provides **2–5x throughput improvement** over "
"the default per-token slice approach at high concurrency and matches "
"homogeneous TP baselines within ~5%."
msgstr ""

#: ../../../advanced_features/pd_disaggregation.md:164
msgid ""
"Enable the staging buffer when prefill and decode use **different TP sizes** "
"with the **Mooncake** transfer backend. When both sides use the same TP "
"size, staging is automatically bypassed even if enabled."
msgstr ""

#: ../../../advanced_features/pd_disaggregation.md:166
msgid ""
"**Note:** The staging buffer is designed for non-MLA models (e.g. GQA, MHA). "
"MLA models (e.g. DeepSeek-V2/V3) should not enable this flag."
msgstr ""

#: ../../../advanced_features/pd_disaggregation.md:168
msgid "Environment Variables"
msgstr ""

#: ../../../advanced_features/pd_disaggregation.md:0
msgid "**`SGLANG_DISAGG_STAGING_BUFFER`**"
msgstr ""

#: ../../../advanced_features/pd_disaggregation.md:0
msgid "Enable GPU staging buffer for heterogeneous TP KV transfer"
msgstr ""

#: ../../../advanced_features/pd_disaggregation.md:0
msgid "`False`"
msgstr ""

#: ../../../advanced_features/pd_disaggregation.md:0
msgid "**`SGLANG_DISAGG_STAGING_BUFFER_SIZE_MB`**"
msgstr ""

#: ../../../advanced_features/pd_disaggregation.md:0
msgid "Prefill-side per-worker staging buffer size in MB"
msgstr ""

#: ../../../advanced_features/pd_disaggregation.md:0
msgid "`64`"
msgstr ""

#: ../../../advanced_features/pd_disaggregation.md:0
msgid "**`SGLANG_DISAGG_STAGING_POOL_SIZE_MB`**"
msgstr ""

#: ../../../advanced_features/pd_disaggregation.md:0
msgid "Decode-side ring buffer pool total size in MB"
msgstr ""

#: ../../../advanced_features/pd_disaggregation.md:0
msgid "`4096`"
msgstr ""

#: ../../../advanced_features/pd_disaggregation.md:176
msgid "Usage Example"
msgstr ""

#: ../../../advanced_features/pd_disaggregation.md:178
msgid ""
"# Set staging buffer environment variables on BOTH prefill and decode\n"
"export SGLANG_DISAGG_STAGING_BUFFER=1\n"
"export SGLANG_DISAGG_STAGING_BUFFER_SIZE_MB=64\n"
"export SGLANG_DISAGG_STAGING_POOL_SIZE_MB=4096\n"
"\n"
"# Prefill with TP=4\n"
"python -m sglang.launch_server \\\n"
"  --model-path $MODEL_PATH \\\n"
"  --disaggregation-mode prefill \\\n"
"  --port 30000 \\\n"
"  --tp 4 \\\n"
"  --trust-remote-code \\\n"
"  --disaggregation-ib-device mlx5_1,mlx5_2\n"
"\n"
"# Decode with TP=1 (or DP attention with effective attention TP=1)\n"
"python -m sglang.launch_server \\\n"
"  --model-path $MODEL_PATH \\\n"
"  --disaggregation-mode decode \\\n"
"  --port 30001 \\\n"
"  --tp 4 \\\n"
"  --dp 4 \\\n"
"  --enable-dp-attention \\\n"
"  --trust-remote-code \\\n"
"  --disaggregation-ib-device mlx5_3,mlx5_4\n"
"\n"
"# Router\n"
"python -m sglang_router.launch_router \\\n"
"  --pd-disaggregation \\\n"
"  --prefill http://127.0.0.1:30000 \\\n"
"  --decode http://127.0.0.1:30001 \\\n"
"  --host 0.0.0.0 --port 8000\n"
msgstr ""

