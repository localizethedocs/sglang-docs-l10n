msgid ""
"By default, NIXL uses the **UCX** backend for KV cache transfers. You can "
"select a different NIXL plugin backend depending on your infrastructure "
"using the environment variable `SGLANG_DISAGGREGATION_NIXL_BACKEND`."
msgstr ""

#: ../../../advanced_features/pd_disaggregation.md:326
msgid "Example: `export SGLANG_DISAGGREGATION_NIXL_BACKEND=LIBFABRIC`"
msgstr ""

#: ../../../advanced_features/pd_disaggregation.md:328
msgid ""
"**Available backends:** UCX (default), LIBFABRIC, or any installed NIXL "
"plugin."
msgstr ""

