#: ../../../advanced_features/hisparse_guide.md:62
msgid "Deployment"
msgstr ""

#: ../../../advanced_features/hisparse_guide.md:64
msgid ""
"HiSparse currently requires **PD disaggregation mode** and is enabled only "
"on the **decode instance**."
msgstr ""

#: ../../../advanced_features/hisparse_guide.md:66
msgid "Prefill Instance"
msgstr ""

#: ../../../advanced_features/hisparse_guide.md:68
msgid ""
"python3 -m sglang.launch_server \\\n"
"    --model-path /path/to/model \\\n"
"    --trust-remote-code \\\n"
"    --port 8000 --host 0.0.0.0 \\\n"
"    --context-length 81920 \\\n"
"    --chunked-prefill-size 65536 \\\n"
"    --tp-size 8 --dp-size 8 --enable-dp-attention \\\n"
"    --mem-fraction-static 0.85 \\\n"
"    --disaggregation-mode prefill \\\n"
"    --disaggregation-ib-device mlx5_0,mlx5_1,mlx5_2,mlx5_3 \\\n"
"    --nnodes 1 --node-rank 0\n"
msgstr ""

#: ../../../advanced_features/hisparse_guide.md:82
msgid "Decode Instance (with HiSparse)"
msgstr ""

#: ../../../advanced_features/hisparse_guide.md:84
msgid ""
"python3 -m sglang.launch_server \\\n"
"    --model-path /path/to/model \\\n"
"    --trust-remote-code \\\n"
"    --port 8000 --host 0.0.0.0 \\\n"
"    --context-length 81920 \\\n"
"    --tp-size 8 --dp-size 8 --enable-dp-attention \\\n"
"    --mem-fraction-static 0.85 \\\n"
"    --kv-cache-dtype bfloat16 \\\n"
"    --nsa-decode-backend flashmla_sparse \\\n"
"    --disaggregation-mode decode \\\n"
"    --disaggregation-ib-device mlx5_0,mlx5_1,mlx5_2,mlx5_3 \\\n"
"    --dist-init-addr 127.0.0.1:5757 \\\n"
"    --nnodes 1 --node-rank 0 \\\n"
"    --enable-hisparse \\\n"
"    --hisparse-config='{\"top_k\": 2048, \"device_buffer_size\": 6144, "
"\"host_to_device_ratio\": 10}'\n"
msgstr ""

